# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=local-dev-secret-key-change-me-in-production

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wiregraph
